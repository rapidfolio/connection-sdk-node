{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "strict": true,
        "strictNullChecks": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "moduleResolution": "NodeNext",
        "declaration": true,
        "declarationMap": true,
        "rootDir": "src",
        "outDir": "dist",
        "types": ["node"]
    },
    "include": ["src"],
    "exclude": ["src/__tests__"]
}
